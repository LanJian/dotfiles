sanitise tridactyllocal tridactylsync

colors jackhxs

bind ,<Space> nohlsearch
bind ; fillcmdline_notrail
bind <C-j> tabnext_gt
bind <C-k> tabprev
bind --mode=browser <C-2> tab #

alias downloads tabopen about:downloads
alias settings tabopen about:preferences
alias preferences tabopen about:preferences

set searchurls.go https://go/

set leavegithubalone false
set blacklistkeys ["/","t","b","o","J","K"]
